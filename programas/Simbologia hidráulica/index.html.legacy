<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ISO 1219 - Hidraulica</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; font-family: system-ui, -apple-system, sans-serif; }
        body { background-color: #0b0f19; color: #f8fafc; padding-bottom: 60px; user-select: none; }
        .app-bar { position: sticky; top: 0; background-color: rgba(11, 15, 25, 0.95); backdrop-filter: blur(10px); border-bottom: 1px solid #1e293b; padding: 12px 14px; z-index: 100; }
        .top-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .brand { display: flex; align-items: center; gap: 8px; }
        .iso-badge { background-color: #b91c1c; color: white; font-weight: 900; font-size: 11px; padding: 3px 6px; border-radius: 6px; }
        .title { font-size: 15px; font-weight: 800; }
        .subtitle { font-size: 10px; color: #64748b; font-weight: 600; display: block; }
        .counter-pill { background: #1e293b; color: #38bdf8; font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 12px; border: 1px solid #334155; }
        .search-container { position: relative; width: 100%; margin-bottom: 10px; }
        .search-input { width: 100%; background: #1a2234; border: 1px solid #2e3c56; border-radius: 10px; padding: 10px 14px; color: white; font-size: 13px; outline: none; }
        .search-input:focus { border-color: #38bdf8; }
        .tabs { display: flex; gap: 8px; }
        .tab-btn { flex: 1; padding: 8px; border-radius: 8px; font-size: 12px; font-weight: 700; border: none; cursor: pointer; transition: all 0.2s; text-align: center; }
        .tab-btn.active { background: #2563eb; color: white; }
        .tab-btn.inactive { background: #1a2234; color: #64748b; border: 1px solid #2e3c56; }
        .main-content { padding: 14px; }
        .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
        .card { background: #121826; border: 1px solid #212b3f; border-radius: 14px; padding: 10px; display: flex; flex-direction: column; justify-content: space-between; align-items: center; cursor: pointer; position: relative; transition: transform 0.1s; }
        .card:active { transform: scale(0.96); }
        .fav-indicator { position: absolute; top: 6px; right: 6px; font-size: 10px; z-index: 10; font-weight: bold; color: #f43f5e; }
        .canvas-box { background: white; width: 100%; height: 90px; border-radius: 10px; display: flex; align-items: center; justify-content: center; padding: 6px; margin-bottom: 8px; box-shadow: inset 0 0 4px rgba(0,0,0,0.1); overflow: hidden; } .canvas-box svg { width: 100% !important; height: 100% !important; max-width: 100% !important; max-height: 78px !important; display: block !important; }
        .card-label { font-size: 11px; font-weight: 700; color: #e2e8f0; text-align: center; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.2; }
        .empty-state { display: none; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; text-align: center; color: #64748b; }
        .empty-state.visible { display: flex; }
        .modal-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.82); backdrop-filter: blur(4px); z-index: 200; display: none; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; padding: 16px; }
        .modal-bg.active { display: flex; opacity: 1; }
        .sheet { width: 100%; max-width: 420px; background: #0f172a; border: 1px solid #2e3c56; border-radius: 24px; padding: 22px; transform: scale(0.92); transition: transform 0.22s ease-out, opacity 0.22s ease-out; opacity: 0; }
        .modal-bg.active .sheet { transform: scale(1); opacity: 1; }
        .drag-handle { width: 40px; height: 4px; background: #334155; border-radius: 2px; margin: 0 auto 16px auto; }
        .sheet-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
        .sheet-meta .tag { font-size: 9px; font-weight: 900; color: #38bdf8; text-transform: uppercase; }
        .sheet-meta h2 { font-size: 16px; font-weight: 800; color: white; margin-top: 2px; }
        .sheet-meta .sub { font-size: 10px; font-family: monospace; color: #64748b; }
        .btn-close { background: #1e293b; color: #94a3b8; border: none; width: 28px; height: 28px; border-radius: 14px; font-weight: bold; cursor: pointer; }
        .sheet-canvas { background: white; border-radius: 16px; padding: 12px; height: 160px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; overflow: hidden; }
        .sheet-canvas svg { width: 100% !important; height: 100% !important; max-height: 140px !important; object-fit: contain !important; }
        .action-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
        .action-btn { padding: 12px; border-radius: 12px; font-size: 13px; font-weight: 700; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px; }
        .btn-fav { background: #1e293b; color: white; border: 1px solid #334155; }
        .btn-fav.favourited { background: rgba(244, 63, 94, 0.15); color: #fb7185; border-color: rgba(244, 63, 94, 0.3); }
        .btn-copy { background: #2563eb; color: white; }
        .toast { position: fixed; top: 16px; left: 50%; transform: translateX(-50%) translateY(-50px); background: #10b981; color: white; font-size: 12px; font-weight: 800; padding: 8px 18px; border-radius: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.4); transition: all 0.2s; opacity: 0; z-index: 999; }
        .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
    </style>
</head>
<body>
    <header class="app-bar">
        <div class="top-row">
            <div class="brand">
                <span class="iso-badge">ISO</span>
                <div>
                    <h1 class="title">Biblioteca Hidraulica</h1>
                    <span class="subtitle">Hidráulica ISO 1219</span>
                </div>
            </div>
            <span id="badge-count" class="counter-pill">0</span>
        </div>
        <div class="search-container">
            <input type="text" id="input-busca" class="search-input" placeholder="Buscar símbolo..." oninput="renderizar()">
        </div>
        <div class="tabs">
            <button id="tab-todos" class="tab-btn active" onclick="setAba('todos')">Todos</button>
            <button id="tab-favs" class="tab-btn inactive" onclick="setAba('favs')">Favoritos (<span id="count-favs">0</span>)</button>
        </div>
    </header>
    <main class="main-content">
        <div id="vazio" class="empty-state">
            <span style="font-size: 34px; margin-bottom: 6px;">!</span>
            <p style="font-size: 13px; font-weight: 600;">Nenhum simbolo coincide</p>
        </div>
        <div id="grid" class="grid"></div>
    </main>
    <div id="modal" class="modal-bg" onclick="fecharModal(event)">
        <div class="sheet" onclick="event.stopPropagation()">
            <div class="sheet-header">
                <div class="sheet-meta">
                    <span class="tag">ISO 1219</span>
                    <h2 id="m-title"></h2>
                </div>
                <button class="btn-close" onclick="fecharModal(true)">X</button>
            </div>
            <div class="sheet-canvas" id="m-svg"></div>
            <div class="action-grid" style="grid-template-columns:1fr;">
                <button id="btn-fav-modal" class="action-btn btn-fav" onclick="alternarFavorito()"></button>
            </div>
        </div>
    </div>
    <div id="toast" class="toast"></div>
    <script data-cfasync="false">
        const BD = [{"id":"Distributeurs cases","titulo":"Casos de Distribuidores","arquivo":"Distributeurs cases.svg","svg":"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"no\"?>\n<!-- Created with Inkscape (http://www.inkscape.org/) -->\n<svg\n   xmlns:dc=\"http://purl.org/dc/elements/1.1/\"\n   xmlns:cc=\"http://web.resource.org/cc/\"\n   xmlns:rdf=\"http://www.w3.org/1999/02/22-rdf-syntax-ns#\"\n   xmlns:svg=\"http://www.w3.org/2000/svg\"\n   xmlns=\"http://www.w3.org/2000/svg\"\n   xmlns:sodipodi=\"http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd\"\n   xmlns:inkscape=\"http://www.inkscape.org/namespaces/inkscape\"\n   width=\"559.10004\"\n   height=\"342.68298\"\n   id=\"svg2\"\n   sodipodi:version=\"0.32\"\n   inkscape:version=\"0.45\"\n   sodipodi:docbase=\"C:\\Documents and Settings\\moi\\Bureau\"\n   sodipodi:docname=\"Distributeurs_cases.svg\"\n   inkscape:output_extension=\"org.inkscape.output.svg.inkscape\"\n   version=\"1.0\"\n   sodipodi:modified=\"true\">\n  <defs\n     id=\"defs4\">\n    <marker\n       inkscape:stockid=\"Arrow2Mstart\"\n       orient=\"auto\"\n       refY=\"0\"\n       refX=\"0\"\n       id=\"Arrow2Mstart\"\n       style=\"overflow:visible\">\n      <path\n         id=\"path6132\"\n         style=\"font-size:12px;fill-rule:evenodd;stroke-width:0.625;stroke-linejoin:round\"\n         d=\"M 8.7185878,4.0337352 L -2.2072895,0.016013256 L 8.7185884,-4.0017078 C 6.97309,-1.6296469 6.9831476,1.6157441 8.7185878,4.0337352 z \"\n         transform=\"scale(0.6,0.6)\" />\n    </marker>\n    <marker\n       inkscape:stockid=\"Arrow2Lend\"\n       orient=\"auto\"\n       refY=\"0\"\n       refX=\"0\"\n       id=\"Arrow2Lend\"\n       style=\"overflow:visible\">\n      <path\n         id=\"path6129\"\n         style=\"font-size:12px;fill-rule:evenodd;stroke-width:0.625;stroke-linejoin:round\"\n         d=\"M 8.7185878,4.0337352 L -2.2072895,0.016013256 L 8.7185884,-4.0017078 C 6.97309,-1.6296469 6.9831476,1.6157441 8.7185878,4.0337352 z