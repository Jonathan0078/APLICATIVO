     d=\"M 92.125984,24.803153 L 92.125984,60.236224\"\n     id=\"path17492\"\n     sodipodi:nodetypes=\"cc\" />\n  <path\n     style=\"fill:none;fill-opacity:0.75;fill-rule:evenodd;stroke:#000000;stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;stroke-opacity:1\"\n     d=\"M 42.519685,21.259846 L 42.519685,31.889767\"\n     id=\"path17494\"\n     sodipodi:nodetypes=\"cc\" />\n  <path\n     style=\"fill:none;fill-opacity:0.75;fill-rule:evenodd;stroke:#000000;stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;stroke-opacity:1\"\n     d=\"M 42.519685,63.779531 L 42.519685,53.149609\"\n     id=\"path17496\"\n     sodipodi:nodetypes=\"cc\" />\n  <path\n     style=\"fill:none;fill-opacity:0.75;fill-rule:evenodd;stroke:#000000;stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;stroke-opacity:1\"\n     d=\"M 85.03937,63.779531 L 85.03937,53.149609\"\n     id=\"path17498\"\n     sodipodi:nodetypes=\"cc\" />\n  <path\n     style=\"fill:none;fill-opacity:0.75;fill-rule:evenodd;stroke:#000000;stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;stroke-opacity:1\"\n     d=\"M 85.03937,31.889767 L 85.03937,21.259846\"\n     id=\"path17500\"\n     sodipodi:nodetypes=\"cc\" />\n  <path\n     style=\"fill:none;fill-opacity:0.75;fill-rule:evenodd;stroke:#000000;stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;stroke-opacity:1\"\n     d=\"M 35.433071,42.519688 L 92.125984,42.519688\"\n     id=\"path17502\" />\n</svg>\n"},{"id":"Teleskopzylinder doppeltwirkend","titulo":"Cilindro Telescópico Duplo Efeito (Alt.)","arquivo":"Teleskopzylinder doppeltwirkend.svg","svg":"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"no\"?>\n<svg xmlns=\"http://www.w3.org/2000/svg\" version=\"1.1\"\n    width=\"105\"\n    height=\"55\">\n  <rect x=\"0\" y=\"0\" width=\"100%\" height=\"100%\" stroke=\"none\" stroke-width=\"0\" fill=\"white\"/>\n  <g transform=\"translate(10,10)\">\n    <rect x=\"0\" y=\"0\" width=\"45\" height=\"25\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <rect x=\"25\" y=\"0\" width=\"20\" height=\"5\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <rect x=\"25\" y=\"20\" width=\"20\" height=\"5\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <rect x=\"40\" y=\"5\" width=\"25\" height=\"5\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <rect x=\"40\" y=\"15\" width=\"25\" height=\"5\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M40,10 h45 v5 h-45\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M3,25 v10\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M42,25 v10\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M62,20 v15\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n  </g>\n</svg>\n"},{"id":"Teleskopzylinder einfachwirkend","titulo":"Cilindro Telescópico Simples Efeito (Alt.)","arquivo":"Teleskopzylinder einfachwirkend.svg","svg":"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"no\"?>\n<svg xmlns=\"http://www.w3.org/2000/svg\" version=\"1.1\"\n    width=\"105\"\n    height=\"55\">\n  <rect x=\"0\" y=\"0\" width=\"100%\" height=\"100%\" stroke=\"none\" stroke-width=\"0\" fill=\"white\"/>\n  <g transform=\"translate(10,10)\">\n    <rect x=\"0\" y=\"0\" width=\"45\" height=\"25\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M25,5 h40 v15 h-40\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M45,10 h40 v5 h-40\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n    <path d=\"M3,25 v10\" stroke=\"black\" stroke-width=\"2.5\" fill=\"white\"/>\n  </g>\n</svg>\n"}];

        function normalizarSVG(svgStr) {
            const div = document.createElement('div');
            div.innerHTML = svgStr;
            const svg = div.querySelector('svg');
            if (svg) {
                if (!svg.getAttribute('viewBox')) {
                    const MM_TO_PX = 3.543307;
                    const toUser = v => (v || '').endsWith('mm') ? parseFloat(v) * MM_TO_PX : parseFloat(v);
                    const wv = toUser(svg.getAttribute('width') || '');
                    const hv = toUser(svg.getAttribute('height') || '');
                    if (wv && hv) svg.setAttribute('viewBox', '0 0 ' + wv + ' ' + hv);
                }
                svg.removeAttribute('width');
                svg.removeAttribute('height');
                svg.style.cssText = '';
                svg.setAttribute('width', '100%');
                svg.setAttribute('height', '100%');
                svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
            }
            return div.innerHTML;
        }

        let abaAtual = 'todos';
        let itemInspecionado = null;
        let favoritos = JSON.parse(localStorage.getItem('favs_iso_hidraulica') || '[]');

        function renderizar() {
            document.getElementById('count-favs').innerText = favoritos.length;
            const termo = document.getElementById('input-busca').value.toLowerCase();
            const filtrados = BD.filter(item => {
                const combina = item.titulo.toLowerCase().includes(termo) || item.arquivo.toLowerCase().includes(termo);
                if (abaAtual === 'favs') return combina && favoritos.includes(item.id);
                return combina;
            });
            document.getElementById('badge-count').innerText = filtrados.length;
            const grid = document.getElementById('grid');
            const estadoVazio = document.getElementById('vazio');
            if (filtrados.length === 0) {
                grid.innerHTML = ''; estadoVazio.classList.add('visible');
            } else {
                estadoVazio.classList.remove('visible');
                grid.innerHTML = filtrados.map(i => {
                    const fav = favoritos.includes(i.id);
                    return `<div class="card" onclick="inspecionar('${i.id}')"><span class="fav-indicator">${fav ? 'FAV' : ''}</span><div class="canvas-box">${normalizarSVG(i.svg)}</div><span class="card-label">${i.titulo}</span></div>`;
                }).join('');
            }
        }
        function setAba(alvo) {
            abaAtual = alvo;
            document.getElementById('tab-todos').className = `tab-btn ${alvo === 'todos' ? 'active' : 'inactive'}`;
            document.getElementById('tab-favs').className = `tab-btn ${alvo === 'favs' ? 'active' : 'inactive'}`;
            renderizar();
        }
        function inspecionar(id) {
            itemInspecionado = BD.find(i => i.id === id);
            document.getElementById('m-title').innerText = itemInspecionado.titulo;
            
            document.getElementById('m-svg').innerHTML = itemInspecionado.svg;
            atualizarBotaoModal(); document.getElementById('modal').classList.add('active');
        }
        function fecharModal(forcar = false) {
            if (forcar || event.target.classList.contains('modal-bg')) { document.getElementById('modal').classList.remove('active'); }
        }
        function atualizarBotaoModal() {
            const isFav = favoritos.includes(itemInspecionado.id);
            const btn = document.getElementById('btn-fav-modal');
            if (isFav) { btn.innerHTML = 'Remover Fav'; btn.className = 'action-btn btn-fav favourited'; } 
            else { btn.innerHTML = 'Favoritar'; btn.className = 'action-btn btn-fav'; }
        }
        function alternarFavorito() {
            const pos = favoritos.indexOf(itemInspecionado.id);
            if (pos === -1) { favoritos.push(itemInspecionado.id); dispararToast("Salvo nos Favoritos"); } 
            else { favoritos.splice(pos, 1); dispararToast("Removido"); }
            localStorage.setItem('favs_iso_hidraulica', JSON.stringify(favoritos));
            atualizarBotaoModal(); renderizar();
        }
        function dispararToast(m) {
            const t = document.getElementById('toast'); t.innerText = "✓ " + m; t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 1800);
        }
        renderizar();
    </script>
<script src="/cdn-cgi/scripts/7d0fa10a/cloudflare-static/rocket-loader.min.js" data-cf-settings="4a5892ab73ad786bab004105-|49" defer></script></body>
