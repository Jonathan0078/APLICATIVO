<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>ISO 1219 - Pneumática</title>
  <link rel="stylesheet" href="../shared/base.css">
  <link rel="stylesheet" href="../../assets/icons/fontawesome.css">
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="app-container">
    <header class="app-header">
      <div class="header-content">
        <h1><i class="fa-solid fa-wind" style="margin-right:8px"></i><span>Biblioteca Pneumática</span></h1>
        <div class="theme-switcher">
          <i class="fa-solid fa-sun"></i>
          <label class="switch">
            <input type="checkbox" id="theme-toggle-checkbox">
            <span class="slider"></span>
          </label>
          <i class="fa-solid fa-moon"></i>
        </div>
      </div>
      <div class="search-container">
        <i class="fa-solid fa-search"></i>
        <input type="text" id="input-busca" class="search-input" placeholder="Buscar símbolo...">
      </div>
      <div class="tabs">
        <button id="tab-todos" class="tab-btn active">Todos</button>
        <button id="tab-favs" class="tab-btn inactive">Favoritos (<span id="count-favs">0</span>)</button>
      </div>
    </header>

    <main class="main-content">
      <div id="vazio" class="empty-state">
        <span>!</span>
        <p>Nenhum símbolo coincide</p>
      </div>
      <div id="grid" class="grid"></div>
    </main>
  </div>

  <div id="modal" class="modal-bg">
    <div class="sheet">
      <div class="sheet-header">
        <div class="sheet-meta">
          <span class="tag">ISO 1219</span>
          <h2 id="m-title"></h2>
        </div>
        <button class="btn-close" id="btn-modal-close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="sheet-body">
        <div class="sheet-canvas" id="m-svg"></div>
        <div class="sheet-descricao">
          <h3><i class="fa-solid fa-circle-info"></i> Descrição</h3>
          <p id="m-descricao"></p>
        </div>
        <div class="sheet-descricao" style="margin-top:0">
          <h3><i class="fa-solid fa-gear"></i> Funcionamento</h3>
          <p id="m-funcionamento"></p>
        </div>
        <div class="sheet-actions">
          <button id="btn-fav-modal" class="action-btn btn-fav"><i class="fa-solid fa-heart"></i> <span id="btn-fav-text">Favoritar</span></button>
          <button id="btn-copy-modal" class="action-btn btn-copy"><i class="fa-solid fa-copy"></i> Copiar SVG</button>
        </div>
      </div>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <script src="database.js"></script>
  <script src="script.js"></script>
</body>
</html>
